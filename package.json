{
	"name": "rizinos",
	"private": true,
	"version": "11.0.0",
	"homepage": "https://rizinos.com",
	"type": "module",
	"scripts": {
		"dev": "concurrently --kill-others \"bun run dev:vite\" \"bun run dev:ws\"",
		"dev:vite": "bun --bun vite dev --port 3002",
		"dev:ws": "bun run --watch src/server.ts",
		"build": "bun --bun vite build && bun build ./src/server.ts --outdir ./build --target bun --sourcemap=linked && bun scripts/generate-pwa-assets.mjs",
		"deploy": "bun run scripts/deploy.ts",
		"preview": "bun run ./build/server.js",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"db:push": "bun node_modules/drizzle-kit/bin.cjs push",
		"db:migrate": "bun node_modules/drizzle-kit/bin.cjs migrate",
		"db:studio": "bun node_modules/drizzle-kit/bin.cjs studio --verbose"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@icons-pack/svelte-simple-icons": "^7.2.0",
		"@internationalized/date": "^3.12.2",
		"@sveltejs/adapter-node": "5.5.4",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.1",
		"@threlte/core": "^8.5.16",
		"@types/bun": "^1.3.14",
		"@types/eslint": "^9.6.1",
		"@types/eslint-config-prettier": "^6.11.3",
		"@types/nodemailer": "^8.0.1",
		"@types/three": "^0.185.0",
		"arctic": "^3.7.0",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.4.0",
		"drizzle-kit": "^1.0.0-beta.22",
		"drizzle-orm": "^1.0.0-beta.22",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"nodemailer": "9.0.1",
		"postgres": "^3.4.9",
		"posthog-js": "^1.395.0",
		"prettier": "^3.9.1",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"shadcn-svelte": "^1.3.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.1",
		"three": "^0.185.0",
		"tw-animate-css": "^1.4.0",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.1.0",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.9",
		"zod": "^4.4.3"
	},
	"dependencies": {
		"@lucide/svelte": "^1.21.0"
	}
}
