{
	"name": "rizinos",
	"private": true,
	"version": "11.0.0",
	"type": "module",
	"scripts": {
		"dev": "concurrently --kill-others \"bun run dev:vite\" \"bun run dev:ws\"",
		"dev:vite": "bun --bun vite dev --port 3002",
		"dev:ws": "bun run --watch src/server.ts",
		"build": "bun --bun vite build && bun build ./src/server.ts --outdir ./build --target bun --sourcemap=linked",
		"deploy": "bun run deploy.ts",
		"preview": "bun run ./build/server.js",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"db:push": "bun node_modules/drizzle-kit/bin.cjs push",
		"db:migrate": "bun node_modules/drizzle-kit/bin.cjs migrate",
		"db:studio": "bun node_modules/drizzle-kit/bin.cjs studio --verbose"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@icons-pack/svelte-simple-icons": "^7.2.0",
		"@internationalized/date": "^3.12.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.4",
		"@threlte/core": "^8.5.9",
		"@types/bun": "^1.3.13",
		"@types/eslint": "^9.6.1",
		"@types/eslint-config-prettier": "^6.11.3",
		"@types/nodemailer": "^8.0.0",
		"@types/three": "^0.184.0",
		"arctic": "^3.7.0",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"daisyui": "^5.5.19",
		"date-fns": "^4.1.0",
		"drizzle-kit": "1.0.0-beta.21",
		"drizzle-orm": "1.0.0-beta.21",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.5.0",
		"nodemailer": "8.0.6",
		"postgres": "^3.4.9",
		"posthog-js": "^1.372.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.3",
		"shadcn-svelte": "^1.3.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.4",
		"three": "^0.184.0",
		"tw-animate-css": "^1.4.0",
		"typescript-eslint": "^8.59.0",
		"vite": "^7.3.2",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.5",
		"zod": "^4.3.6"
	},
	"dependencies": {
		"@lucide/svelte": "^1.21.0"
	}
}
